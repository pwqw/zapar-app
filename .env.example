# Copiar a `.env` en la raíz del repo (`.env` está en .gitignore).
# Valores por defecto alineados con upstream Koel; personaliza solo lo necesario.

# Android package id (también puedes usar android/applicationId en android/local.properties)
ANDROID_APPLICATION_ID=phanan.koel.app

# Docker / Makefile (prefijo coherente con volúmenes en targets cache-*)
IMAGE_NAME=koel-dev
CONTAINER_NAME_DEV=koel-dev
CONTAINER_NAME_TEST=koel-dev-test
DOCKER_VOLUME_PREFIX=koel
